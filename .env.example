# Public Supabase client configuration (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key

# Server-only Supabase key for secure backend operations
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Edge Function base URL used by web clients
NEXT_PUBLIC_SUPABASE_FUNCTIONS_BASE_URL=https://your-project-ref.supabase.co/functions/v1/aegis-api
# Optional server-side alias; can match NEXT_PUBLIC_SUPABASE_FUNCTIONS_BASE_URL
SUPABASE_FUNCTIONS_BASE_URL=https://your-project-ref.supabase.co/functions/v1/aegis-api

# OpenWeatherMap API key used for rain probability decisions
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

